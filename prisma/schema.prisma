generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Operateur {
  id                 String    @id @default(uuid())
  ifu                String?   @unique
  lan                String?   @unique
  nom                String
  prenom             String
  email              String    @unique
  telephone          String    @unique
  motDePasse         String
  secteur            Secteur
  niveau             Niveau    @default(STARTER)
  statut             Statut    @default(ACTIF)
  scoreConformite    Int       @default(0)
  role               String    @default("OPERATEUR")
  dateInscription    DateTime  @default(now())
  dateRenouvellement DateTime?
  factures           Facture[]
  depenses           Depense[]
  declarations       DeclarationFiscale[]
  progressions       ProgressionFormation[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("operateurs")
}

enum Secteur {
  DROPSHIPPING
  ECOMMERCE
  FREELANCE
  INFLUENCE
  CONTENU
  FORMATION
  COACHING
  TRADING
  CRYPTOACTIFS
  DEVELOPPEMENT
  AUTRE
}

enum Niveau {
  STARTER
  BUILDER
  ACHIEVER
  CHAMPION
  ELITE
}

enum Statut {
  ACTIF
  SUSPENDU
  RADIE
  EN_ATTENTE
}

model Facture {
  id              String        @id @default(uuid())
  numero          String        @unique
  operateur       Operateur     @relation(fields: [operateurId], references: [id])
  operateurId     String
  clientNom       String
  clientEmail     String?
  clientTelephone String?
  clientIfu       String?
  dateEmission    DateTime
  dateEcheance    DateTime?
  lignes          Json
  montantHT       Decimal       @db.Decimal(15, 2)
  tva             Decimal       @default(0) @db.Decimal(15, 2)
  montantTTC      Decimal       @db.Decimal(15, 2)
  statut          StatutFacture @default(EMISE)
  modeLivraison   String[]
  dgiReference    String?
  dgiSync         Boolean       @default(false)
  dgiSyncAt       DateTime?
  pdfUrl          String?
  createdAt       DateTime      @default(now())

  @@map("factures")
}

enum StatutFacture {
  EMISE
  PAYEE
  ANNULEE
}

model Depense {
  id               String           @id @default(uuid())
  operateur        Operateur        @relation(fields: [operateurId], references: [id])
  operateurId      String
  dateDepense      DateTime
  categorie        CategorieDepense
  description      String?
  montant          Decimal          @db.Decimal(15, 2)
  devise           String           @default("XOF")
  montantXof       Decimal          @db.Decimal(15, 2)
  fournisseurNom   String?
  fournisseurIfu   String?
  justificatifType TypeJustificatif?
  justificatifUrl  String?
  justificatifRef  String?
  statutValidation StatutValidation @default(EN_ATTENTE)
  validationNote   String?
  createdAt        DateTime         @default(now())

  @@map("depenses")
}

enum CategorieDepense {
  STOCK_LOCAL
  STOCK_ETRANGER
  PUB_META
  PUB_GOOGLE
  ABONNEMENT_OUTIL
  LIVRAISON_LOCAL
  LIVRAISON_INTERNATIONAL
  TELECOM
  MATERIEL
  PRESTATAIRE_SNAEN
  AUTRE
}

enum TypeJustificatif {
  FACTURE_NORMALISEE
  FACTURE_ETRANGERE
  RECU_MOBILE_MONEY
  RECU_EMAIL
  AUTRE
}

enum StatutValidation {
  AUTO_VALIDEE
  VALIDEE
  REJETEE
  EN_ATTENTE
  AUDIT_REQUIS
}

model DeclarationFiscale {
  id               String           @id @default(uuid())
  operateur        Operateur        @relation(fields: [operateurId], references: [id])
  operateurId      String
  periode          String
  caTotal          Decimal          @db.Decimal(15, 2)
  depensesValidees Decimal          @default(0) @db.Decimal(15, 2)
  beneficeNet      Decimal          @db.Decimal(15, 2)
  tauxApplique     Decimal          @db.Decimal(5, 2)
  regime           RegimeFiscal
  impotCalcule     Decimal          @db.Decimal(15, 2)
  reductionNiveau  Decimal          @default(0) @db.Decimal(5, 2)
  impotFinal       Decimal          @db.Decimal(15, 2)
  statut           StatutDeclaration @default(CALCULEE)
  dateLimite       DateTime
  datePaiement     DateTime?
  createdAt        DateTime         @default(now())

  @@map("declarations_fiscales")
}

enum RegimeFiscal {
  BENEFICE_REEL
  FORFAIT_SECTORIEL
}

enum StatutDeclaration {
  CALCULEE
  PAYEE
  EN_RETARD
}

model Formation {
  id           String                @id @default(uuid())
  titre        String
  description  String?
  niveauMin    Niveau                @default(STARTER)
  dureeMin     Int
  format       String
  gratuit      Boolean               @default(true)
  secteurs     Secteur[]
  actif        Boolean               @default(true)
  progressions ProgressionFormation[]

  @@map("formations")
}

model ProgressionFormation {
  id            String    @id @default(uuid())
  operateur     Operateur @relation(fields: [operateurId], references: [id])
  operateurId   String
  formation     Formation @relation(fields: [formationId], references: [id])
  formationId   String
  progressionPct Int      @default(0)
  termine       Boolean   @default(false)
  dateDebut     DateTime?
  dateFin       DateTime?
  certificatUrl String?

  @@map("progressions_formations")
}

model DossierCVFD {
  id                 String        @id @default(uuid())
  typeDetection      String
  sujetNom           String
  sujetTelephone     String?
  sujetEmail         String?
  sujetProfilUrl     String?
  description        String
  preuves            Json?
  statut             StatutDossier @default(OUVERT)
  agentId            String?
  dateDetection      DateTime      @default(now())
  dateMiseDemeure    DateTime?
  dateRegularisation DateTime?
  notesAgent         String?
  createdAt          DateTime      @default(now())

  @@map("dossiers_cvfd")
}

enum StatutDossier {
  OUVERT
  EN_ENQUETE
  MISE_EN_DEMEURE
  REGULARISE
  CLASSE
  TRANSMIS_JUSTICE
}
